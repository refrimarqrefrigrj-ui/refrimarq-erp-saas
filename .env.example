# ------------------------------------------------------------------
# Modelo de variáveis de ambiente do ERP HVAC.
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# NUNCA comite o `.env.local` (ele está no .gitignore) — contém segredos.
# ------------------------------------------------------------------

# --- Clerk (autenticação) ---
# Painel: https://dashboard.clerk.com -> sua aplicação -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=coloque_aqui_a_publishable_key
CLERK_SECRET_KEY=coloque_aqui_a_secret_key

# Rotas de autenticação (onde ficam as telas de login/cadastro no nosso app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cadastro
# Para onde ir depois de entrar/cadastrar (se não houver redirect específico)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Neon (banco de dados PostgreSQL) — será usado no próximo passo ---
# Painel: https://console.neon.tech -> seu projeto -> Connection string
DATABASE_URL=coloque_aqui_a_connection_string_do_neon
