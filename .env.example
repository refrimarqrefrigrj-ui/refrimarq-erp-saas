# ------------------------------------------------------------------
# Modelo de variáveis de ambiente do ERP HVAC.
# Copie este arquivo para `.env.local` e preencha com os valores reais.
# NUNCA comite o `.env.local` (ele está no .gitignore) — contém segredos.
# ------------------------------------------------------------------

# --- Auth.js (autenticação) ---
# Gere um valor com: npx auth secret   (ou node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=coloque_aqui_um_segredo_aleatorio

# --- Neon (banco de dados PostgreSQL) ---
# Painel: https://console.neon.tech -> seu projeto -> Connection string
DATABASE_URL=coloque_aqui_a_connection_string_do_neon
